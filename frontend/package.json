{
  "name": "raccoon-node-frontend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "tsc -b && vite build",
    "check": "tsc -b --noEmit && npm run format:check",
    "test": "vitest",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,css}\"",
    "format": "prettier --write \"src/**/*.{ts,tsx,css}\""
  },
  "dependencies": {
    "@astryxdesign/cli": "^0.1.3",
    "@astryxdesign/core": "^0.1.3",
    "@astryxdesign/theme-butter": "^0.1.3",
    "@astryxdesign/theme-chocolate": "^0.1.3",
    "@astryxdesign/theme-gothic": "^0.1.3",
    "@astryxdesign/theme-matcha": "^0.1.3",
    "@astryxdesign/theme-neutral": "^0.1.3",
    "@astryxdesign/theme-stone": "^0.1.3",
    "@astryxdesign/theme-y2k": "^0.1.3",
    "@stylexjs/stylex": "^0.18.3",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "@xyflow/react": "^12.10.0",
    "lucide-react": "^0.562.0",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.4.0",
    "@testing-library/react": "^16.0.0",
    "@types/node": "^20.17.0",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "jsdom": "^24.0.0",
    "prettier": "^3.3.3",
    "typescript": "^5.9.3",
    "vite": "^7.2.7",
    "vitest": "^2.0.0"
  }
}
